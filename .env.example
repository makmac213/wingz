# Copy to `.env` and adjust for your environment.

# Django secret key. Generate one for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-key-change-me-in-production

# Debug mode — NEVER True in production.
DEBUG=True

# Comma-separated list of allowed hostnames.
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (development uses the bundled SQLite file by default).
# For production PostgreSQL:
#   DATABASE_URL=postgresql://user:password@localhost:5432/wingz
